<!--
Template only. This best-effort UiPath XAML skeleton is an implementation aid,
not a guaranteed executable workflow. A human builder must configure packages,
activities, browser selectors, HTTP Request activities, approval tasks, and
tenant-specific settings in UiPath Studio.

UiPath remains the main orchestration, governance, approval, RPA, validation,
trusted-tool registration, and API-mode execution layer. This file does not move
orchestration into Python and does not imply Codex runs at UiPath runtime.
-->
<Activity x:Class="Main"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:s="clr-namespace:System;assembly=System.Private.CoreLib">
  <Sequence DisplayName="Agentic ERP Modernization Layer - UiPath Template">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="case_id" Default="CASE-001" />
      <Variable x:TypeArguments="x:String" Name="po_id" Default="PO-1001" />
      <Variable x:TypeArguments="x:String" Name="current_stage" Default="CASE_INTAKE" />
      <Variable x:TypeArguments="x:Double" Name="amount" Default="0" />
      <Variable x:TypeArguments="x:Double" Name="budget_limit" Default="0" />
      <Variable x:TypeArguments="x:String" Name="vendor_id" Default="" />
      <Variable x:TypeArguments="x:Boolean" Name="vendor_info_complete" Default="False" />
      <Variable x:TypeArguments="x:Boolean" Name="inventory_available" Default="False" />
      <Variable x:TypeArguments="x:String" Name="erp_status" Default="" />
      <Variable x:TypeArguments="x:String" Name="raw_exception_text" Default="" />
      <Variable x:TypeArguments="x:String" Name="triage_result_json" Default="" />
      <Variable x:TypeArguments="x:String" Name="detected_exception_type" Default="" />
      <Variable x:TypeArguments="x:String" Name="risk_level" Default="" />
      <Variable x:TypeArguments="x:Boolean" Name="requires_human_approval" Default="False" />
      <Variable x:TypeArguments="x:String" Name="next_stage" Default="" />
      <Variable x:TypeArguments="x:String" Name="human_approval_status" Default="pending" />
      <Variable x:TypeArguments="x:String" Name="execution_mode" Default="RPA" />
      <Variable x:TypeArguments="x:String" Name="validation_status" Default="not_started" />
      <Variable x:TypeArguments="x:String" Name="trusted_tool_status" Default="not_registered" />
      <Variable x:TypeArguments="x:String" Name="validation_result_json" Default="" />
      <Variable x:TypeArguments="x:String" Name="api_result_json" Default="" />
      <Variable x:TypeArguments="x:String" Name="final_case_output_json" Default="" />
    </Sequence.Variables>

    <Assign DisplayName="Initialize Case Stage">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[current_stage]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">CASE_INTAKE</InArgument>
      </Assign.Value>
    </Assign>

    <WriteLine DisplayName="Log Case Intake" Text="[&quot;Case Intake started: &quot; + case_id + &quot; / &quot; + po_id]" />

    <Sequence DisplayName="Legacy ERP Extraction">
      <WriteLine Text="Open Browser / Use Browser: http://localhost:8000/purchase-orders/PO-1001" />
      <WriteLine Text="Get Text id=po-id into po_id" />
      <WriteLine Text="Get Text id=amount into amount" />
      <WriteLine Text="Get Text id=budget-limit into budget_limit" />
      <WriteLine Text="Get Text id=vendor-id into vendor_id" />
      <WriteLine Text="Get Text id=vendor-info-complete into vendor_info_complete" />
      <WriteLine Text="Get Text id=inventory-available into inventory_available" />
      <WriteLine Text="Get Text id=erp-status into erp_status" />
      <WriteLine Text="Get Text id=raw-exception-text into raw_exception_text" />
      <Assign DisplayName="Set Extraction Complete">
        <Assign.To>
          <OutArgument x:TypeArguments="x:String">[current_stage]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:String">LEGACY_ERP_EXTRACTION_COMPLETE</InArgument>
        </Assign.Value>
      </Assign>
    </Sequence>

    <Sequence DisplayName="Exception Triage">
      <WriteLine Text="HTTP Request POST http://localhost:8001/triage" />
      <WriteLine Text="Deserialize JSON and assign detected_exception_type, risk_level, requires_human_approval, next_stage" />
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:String">[current_stage]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:String">EXCEPTION_TRIAGE_COMPLETE</InArgument>
        </Assign.Value>
      </Assign>
    </Sequence>

    <Switch x:TypeArguments="x:String" DisplayName="Flow Switch on detected_exception_type" Expression="[detected_exception_type]">
      <Switch.Default>
        <Sequence DisplayName="unknown_exception">
          <Assign>
            <Assign.To>
              <OutArgument x:TypeArguments="x:String">[current_stage]</OutArgument>
            </Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:String">WAITING_MANUAL_INVESTIGATION</InArgument>
            </Assign.Value>
          </Assign>
          <WriteLine Text="Human manual investigation placeholder." />
        </Sequence>
      </Switch.Default>
      <Sequence x:Key="budget_exceeded" DisplayName="budget_exceeded">
        <Assign>
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[current_stage]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">WAITING_FOR_HUMAN_APPROVAL</InArgument>
          </Assign.Value>
        </Assign>
        <WriteLine Text="Business human approval placeholder controlled by UiPath." />
        <Assign>
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[human_approval_status]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">approved</InArgument>
          </Assign.Value>
        </Assign>
      </Sequence>
      <Sequence x:Key="vendor_info_missing" DisplayName="vendor_info_missing">
        <Assign>
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[current_stage]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">WAITING_VENDOR_INFO</InArgument>
          </Assign.Value>
        </Assign>
        <WriteLine Text="PO-1002 lightweight route proof. Routing uses detected_exception_type, not po_id." />
      </Sequence>
      <Sequence x:Key="inventory_shortage" DisplayName="inventory_shortage">
        <Assign>
          <Assign.To>
            <OutArgument x:TypeArguments="x:String">[current_stage]</OutArgument>
          </Assign.To>
          <Assign.Value>
            <InArgument x:TypeArguments="x:String">WAITING_INVENTORY_REVIEW</InArgument>
          </Assign.Value>
        </Assign>
        <WriteLine Text="Inventory review placeholder controlled by UiPath." />
      </Sequence>
    </Switch>

    <Sequence DisplayName="Legacy RPA Write-back">
      <WriteLine Text="Type Into id=approval-reason-input: Amount exceeds budget limit" />
      <WriteLine Text="Type Into id=manager-id-input: MGR-001" />
      <WriteLine Text="Click id=request-approval-button" />
      <WriteLine Text="Verify writeback-status, writeback-execution-mode, writeback-audit-created" />
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:String">[current_stage]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:String">LEGACY_RPA_WRITEBACK_COMPLETE</InArgument>
        </Assign.Value>
      </Assign>
    </Sequence>

    <Sequence DisplayName="Validation Gate">
      <WriteLine Text="HTTP Request POST http://localhost:8003/validate/request-purchase-order-approval" />
      <WriteLine Text="Deserialize validation_result_json and verify passed tests." />
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:String">[validation_status]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:String">passed</InArgument>
        </Assign.Value>
      </Assign>
    </Sequence>

    <Sequence DisplayName="Trusted Tool Approval">
      <WriteLine Text="Trusted tool registration approval placeholder controlled by UiPath." />
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:String">[trusted_tool_status]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:String">registered</InArgument>
        </Assign.Value>
      </Assign>
    </Sequence>

    <Sequence DisplayName="API Mode Execution">
      <WriteLine Text="HTTP Request POST http://localhost:8002/api/purchase-orders/PO-1001/approval-request" />
      <WriteLine Text="Deserialize api_result_json and verify execution_mode = API." />
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:String">[execution_mode]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:String">API</InArgument>
        </Assign.Value>
      </Assign>
      <Assign>
        <Assign.To>
          <OutArgument x:TypeArguments="x:String">[current_stage]</OutArgument>
        </Assign.To>
        <Assign.Value>
          <InArgument x:TypeArguments="x:String">API_MODE_EXECUTED</InArgument>
        </Assign.Value>
      </Assign>
    </Sequence>

    <Assign DisplayName="Build Final Case Output JSON">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[final_case_output_json]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[&quot;{&quot;&quot;case_id&quot;&quot;:&quot;&quot;&quot; + case_id + &quot;&quot;&quot;,&quot;&quot;po_id&quot;&quot;:&quot;&quot;&quot; + po_id + &quot;&quot;&quot;,&quot;&quot;current_stage&quot;&quot;:&quot;&quot;&quot; + current_stage + &quot;&quot;&quot;,&quot;&quot;detected_exception_type&quot;&quot;:&quot;&quot;&quot; + detected_exception_type + &quot;&quot;&quot;,&quot;&quot;risk_level&quot;&quot;:&quot;&quot;&quot; + risk_level + &quot;&quot;&quot;,&quot;&quot;human_approval_status&quot;&quot;:&quot;&quot;&quot; + human_approval_status + &quot;&quot;&quot;,&quot;&quot;validation_status&quot;&quot;:&quot;&quot;&quot; + validation_status + &quot;&quot;&quot;,&quot;&quot;trusted_tool_status&quot;&quot;:&quot;&quot;&quot; + trusted_tool_status + &quot;&quot;&quot;,&quot;&quot;execution_mode&quot;&quot;:&quot;&quot;&quot; + execution_mode + &quot;&quot;&quot;}&quot;]</InArgument>
      </Assign.Value>
    </Assign>

    <WriteLine DisplayName="Log Final Case Output" Text="[final_case_output_json]" />
  </Sequence>
</Activity>
