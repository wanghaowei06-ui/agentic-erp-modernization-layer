# Copy this file to .env and fill in your real key for local demo runs.
# .env is ignored by git and should not be committed.

LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=put-your-real-deepseek-api-key-here
LLM_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=2

# CI/local smoke only. Leave unset or empty for real LLM mode.
# LLM_DEMO_MODE=mock_success
